# RFQ E2E Test Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# Environment Selection
# ============================================================
# Which environment to run tests against: local | devnet0 | devnet1 | devnet3 | testnet
RFQ_ENV=local

# ============================================================
# Local Environment Credentials
# ============================================================
# Admin wallet for register_maker (contract internal admin)
# On local, this is the deterministic deployment key (VALIDATOR_MNEMONIC index 1)
# Address: inj1d7ky6xxfzg6rh7r05uzfxexafepy4wwqp4z8h8
# PK: 9a983cb3d832fbde5ab49d692b7a8bf5b5d232479c99333d0fc8e1d21f1b55b6
# Note: The contract's CosmWasm admin (for migrations) is different: inj17gkuet8f6pssxd8nycm3qr9d9y699rupv6397z
LOCAL_ADMIN_PRIVATE_KEY=

# Single wallets for quick functional tests
LOCAL_RETAIL_PRIVATE_KEY=
LOCAL_MM_PRIVATE_KEY=

# Load test seed phrases (for generating 100-1000+ wallets)
LOCAL_LOAD_TEST_MM_SEED_PHRASE=
LOCAL_LOAD_TEST_RETAIL_SEED_PHRASE=

# ============================================================
# Devnet0 Environment Credentials
# ============================================================
# Admin wallet (contract deployer)
DEVNET0_ADMIN_PRIVATE_KEY=

# Single wallets for quick functional tests
DEVNET0_RETAIL_PRIVATE_KEY=
DEVNET0_MM_PRIVATE_KEY=

# Load test seed phrases (for generating 100-1000+ wallets)
DEVNET0_LOAD_TEST_MM_SEED_PHRASE=
DEVNET0_LOAD_TEST_RETAIL_SEED_PHRASE=

# ============================================================
# Devnet1 Environment Credentials
# ============================================================
# Admin wallet (contract deployer)
DEVNET1_ADMIN_PRIVATE_KEY=

# Single wallets for quick functional tests
DEVNET1_RETAIL_PRIVATE_KEY=
DEVNET1_MM_PRIVATE_KEY=

# Load test seed phrases (for generating 100-1000+ wallets)
DEVNET1_LOAD_TEST_MM_SEED_PHRASE=
DEVNET1_LOAD_TEST_RETAIL_SEED_PHRASE=

# ============================================================
# Devnet3 Environment Credentials
# ============================================================
# Admin wallet (contract deployer)
DEVNET3_ADMIN_PRIVATE_KEY=

# Single wallets for quick functional tests
DEVNET3_RETAIL_PRIVATE_KEY=
DEVNET3_MM_PRIVATE_KEY=

# Load test seed phrases (for generating 100-1000+ wallets)
DEVNET3_LOAD_TEST_MM_SEED_PHRASE=
DEVNET3_LOAD_TEST_RETAIL_SEED_PHRASE=

# ============================================================
# Testnet Environment Credentials
# ============================================================
# Testnet uses the same wallets as devnet: copy DEVNET0_* values to TESTNET_*.
# Admin wallet (contract deployer)
TESTNET_ADMIN_PRIVATE_KEY=

# Single wallets for quick functional tests
TESTNET_RETAIL_PRIVATE_KEY=
TESTNET_MM_PRIVATE_KEY=

# Load test seed phrases (same as devnet if using same wallet set)
TESTNET_LOAD_TEST_MM_SEED_PHRASE=
TESTNET_LOAD_TEST_RETAIL_SEED_PHRASE=

# ============================================================
# Faucet API (for devnet/testnet wallet funding)
# ============================================================
FAUCET_API_URL=https://faucet.injective.dev/api/v1/faucet

# ============================================================
# Optional Endpoint Overrides
# These override the values in configs/*.yaml if set
# ============================================================
# RFQ_WS_URL=
# RFQ_HTTP_URL=
# CHAIN_GRPC_URL=
# CHAIN_LCD_URL=
